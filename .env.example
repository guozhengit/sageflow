# SageFlow 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ============ 数据库配置 ============
DB_PASSWORD=your-secure-db-password
DATABASE_URL=postgresql://sageflow:your-secure-db-password@postgres:5432/sageflow

# ============ Qdrant 配置 ============
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=sageflow_docs

# ============ Redis 配置 ============
REDIS_URL=redis://redis:6379/0

# ============ Ollama 配置 ============
OLLAMA_URL=http://ollama:11434
LLM_MODEL=qwen2.5:3b

# ============ JWT 配置 ============
# 重要: 使用强密钥！生成命令: openssl rand -hex 32
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256

# ============ 文件上传配置 ============
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/uploads

# ============ 应用配置 ============
APP_NAME=SageFlow
APP_VERSION=0.6.0
DEBUG=false

# ============ CORS 配置 ============
# 允许的源地址 (逗号分隔)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ 生产环境额外配置 ============
# 生产环境请确保:
# 1. JWT_SECRET 使用强密钥 (至少 32 字符)
# 2. DB_PASSWORD 使用强密码
# 3. DEBUG=false
# 4. ALLOWED_ORIGINS 只包含实际域名
